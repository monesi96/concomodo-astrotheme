

{% liquid
  assign product = closest.product
-%}

{% capture children %}
  {% content_for 'blocks', closest.product: product %}
  {%- comment -%}
    Recommendation cards (topper, accessori) can be added to the cart inheriting the size
    selected on the main product. `recommendations.performed` is only true inside the
    /recommendations/products request, which is the one that renders those cards.
  {%- endcomment -%}
  {% if recommendations.performed %}
    {% render 'linked-size-add', product: product, section_id: section.id %}
  {% endif %}
{% endcapture %}

{% render 'product-card', children: children, product: product %}

{% stylesheet %}
  linked-size-add[hidden] {
    display: none;
  }

  .linked-size-add {
    display: block;
    width: 100%;
    margin-block-start: var(--padding-xs);
  }

  /* Our button replaces the theme's "Scegli" overlay, which would open a second picker. */
  product-card:has(linked-size-add:not([hidden])) .quick-add {
    display: none;
  }

  /* The real theme product form: functional, never shown. */
  .linked-size-add__form {
    display: none;
  }

  /* Colours, hovers and radii come from .button / .button-secondary and the card's scheme. */
  .linked-size-add__trigger {
    width: 100%;
  }

  .linked-size-add__dialog {
    width: min(28rem, calc(100vw - 2rem));
    padding: 0;
    border: 0;
    border-radius: 20px;
    background: var(--color-background);
    color: var(--color-foreground);
  }

  .linked-size-add__dialog::backdrop {
    background: hsl(0deg 0% 0% / 55%);
  }

  .linked-size-add__dialog-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--padding-sm);
    padding: var(--padding-lg);
    cursor: auto;
  }

  .linked-size-add__close {
    position: absolute;
    z-index: var(--layer-flat);
    inset-block-start: var(--padding-xs);
    inset-inline-end: var(--padding-xs);
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--minimum-touch-target);
    height: var(--minimum-touch-target);
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: none;
    color: inherit;
    cursor: pointer;
    transition: opacity var(--animation-speed) var(--animation-easing);
  }

  .linked-size-add__close:hover {
    opacity: 0.6;
  }

  .linked-size-add__close svg {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
    pointer-events: none;
  }

  .linked-size-add__eyebrow {
    margin: 0;
    font-size: var(--font-size--xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .linked-size-add__summary {
    display: flex;
    align-items: center;
    gap: var(--padding-sm);
  }

  .linked-size-add__image {
    width: 5rem;
    height: 5rem;
    flex: none;
    border-radius: 12px;
    object-fit: cover;
  }

  .linked-size-add__summary-text {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .linked-size-add__title {
    margin: 0;
    font-size: var(--font-size--md);
    font-weight: 500;
  }

  .linked-size-add__specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.25rem;
    margin: 0;
    font-size: var(--font-size--sm);
  }

  .linked-size-add__spec {
    display: flex;
    gap: 0.4rem;
  }

  .linked-size-add__spec dt {
    opacity: 0.6;
  }

  .linked-size-add__spec dd {
    margin: 0;
    font-weight: 500;
  }

  .linked-size-add__price-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-block: var(--padding-sm);
    border-block: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
  }

  .linked-size-add__price-label {
    font-size: var(--font-size--sm);
    opacity: 0.6;
  }

  .linked-size-add__price-value {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: var(--font-size--lg);
    font-weight: 500;
  }

  .linked-size-add__compare {
    font-size: var(--font-size--sm);
    font-weight: 400;
    opacity: 0.5;
  }

  .linked-size-add__note {
    margin: 0;
    font-size: var(--font-size--xs);
    opacity: 0.6;
  }

  .linked-size-add__actions {
    display: flex;
    gap: var(--padding-xs);
  }

  .linked-size-add__actions :is(.button, .button-secondary) {
    flex: 1;
    width: auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_card",
  "blocks": [
    {
      "type": "_product-card-group"
    },
    {
      "type": "text"
    },
    {
      "type": "image"
    },
    {
      "type": "buy-buttons"
    },
    {
      "type": "price"
    },
    {
      "type": "review"
    },
    {
      "type": "sku"
    },
    {
      "type": "swatches"
    },
    {
      "type": "_product-card-gallery"
    },
    {
      "type": "product-title"
    },
    {
      "type": "product-features"
    },
    {
      "type": "custom-liquid"
    },
    {
      "type": "@app"
    }
  ],
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_card"
    },
    {
      "type": "range",
      "id": "product_card_gap",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "t:content.borders"
    },
    {
      "type": "select",
      "id": "border",
      "label": "t:settings.style",
      "options": [
        {
          "value": "none",
          "label": "t:options.none"
        },
        {
          "value": "solid",
          "label": "t:options.solid"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "t:settings.thickness",
      "default": 1,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "t:settings.opacity",
      "default": 100,
      "visible_if": "{{ block.settings.border != 'none' }}"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
