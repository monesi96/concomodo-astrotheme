    {
      "type": "header",
      "content": "Bottoni"
    },
    {
      "type": "text",
      "id": "add_label",
      "label": "Testo bottone aggiungi (cuscino)",
      "default": "Aggiungi"
    },
    {
      "type": "text",
      "id": "remove_label",
      "label": "Testo bottone rimuovi",
      "default": "Rimuovi"
    },
    {
      "type": "text",
      "id": "unavailable_label",
      "label": "Testo misura non disponibile",
      "default": "Non disponibile"
    },
    {
      "type": "header",
      "content": "Stile"
    },
    {
      "type": "color_scheme",
      "id": "card_scheme",
      "label": "Schema colori card",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Raggio card",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
