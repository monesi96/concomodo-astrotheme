{%- doc -%}
  Product page upsell with a guided choice:

  - Any number of "Prodotto consigliato" child cards (typically the two
    toppers) in mutually exclusive choice: adding one removes the others. Each
    card inherits Dimensione/Misure from the main product like linked-size-add
    and is styled like the theme's native product cards. Cards sit side by side
    on desktop and become a swipe carousel when they don't fit.
  - A gift pillow as a horizontal card: added automatically (free of charge)
    when a topper is chosen, or purchasable alone at a configurable display
    discount.
  - Bundle behaviour: every add also puts the main product (the mattress, in
    the selected size) in the cart when it is not there yet — one click buys
    the whole bundle.

  The block only *shows* the promotional prices: the actual cart prices must be
  backed by two automatic discounts in the Shopify admin (see the schema note).
{%- enddoc -%}

{%- liquid
  assign gift_product = block.settings.gift_product
-%}

<script src="{{ 'product-upsell.js' | asset_url }}" type="module"></script>

  <product-upsell
    class="
      product-upsell
      {% unless block.settings.inherit_color_scheme %}color-{{ block.settings.color_scheme }}{% endunless %}
      spacing-style
    "
    style="
      {% render 'spacing-style', settings: block.settings %}
      --product-upsell-card-radius: {{ block.settings.card_radius }}px;
    "
    data-gift-enabled="{{ block.settings.gift_enabled }}"
    data-solo-percent="{{ block.settings.solo_discount_percent }}"
    data-gift-cart-property="{{ block.settings.gift_cart_property | escape }}"
    data-bundle-main="{{ block.settings.bundle_main }}"
    data-topper-keyword="{{ block.settings.topper_keyword | escape }}"
    data-mattress-keyword="{{ block.settings.mattress_keyword | escape }}"
    {{ block.shopify_attributes }}
  >
    {%- if block.settings.heading != blank -%}
      <h4 class="product-upsell__heading">{{ block.settings.heading }}</h4>
    {%- endif -%}

    {%- if block.settings.hint != blank -%}
      <p class="product-upsell__hint">{{ block.settings.hint }}</p>
    {%- endif -%}

    <div class="product-upsell__choice color-{{ block.settings.card_scheme }}">
      {% content_for 'blocks' %}
    </div>

    {%- if gift_product != blank -%}
      {% render 'product-upsell-item',
        product: gift_product,
        role: 'gift',
        benefit: block.settings.gift_text,
        add_label: block.settings.add_label,
        remove_label: block.settings.remove_label,
        unavailable_label: block.settings.unavailable_label,
        card_scheme: block.settings.card_scheme,
        solo_percent: block.settings.solo_discount_percent,
        solo_badge: block.settings.solo_badge,
        gift_badge: block.settings.gift_badge,
        gift_free_label: block.settings.gift_free_label
      %}
    {%- elsif request.design_mode -%}
      <p class="product-upsell__setup">
        Upsell prodotto: aggiungi le card dei topper come blocchi qui dentro e
        scegli il cuscino nelle impostazioni del blocco.
      </p>
    {%- endif -%}
  </product-upsell>

{% stylesheet %}
  .product-upsell {
    display: block;
    width: 100%;
  }

  .product-upsell [hidden] {
    display: none !important;
  }

  .product-upsell__heading {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 1rem;
    font-weight: 500;
  }

  .product-upsell__hint {
    margin: 4px 0 0;
    font-size: var(--font-size--xs);
    opacity: 0.7;
  }

  /* The cards: one scroll-snap row on every viewport. With one or two cards it
     reads as a plain side-by-side grid; from the third card on it scrolls. */
  .product-upsell__choice {
    display: flex;
    gap: 12px;
    margin-block-start: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 2px;
  }

  .product-upsell__choice::-webkit-scrollbar {
    display: none;
  }

  /* No card blocks configured: collapse the empty row */
  .product-upsell__choice:not(:has(> .product-upsell__card)) {
    display: none;
  }

  .product-upsell__choice > .product-upsell__card {
    flex: 1 0 calc(50% - 6px);
    min-width: 0;
    scroll-snap-align: start;
  }

  /* Every card shares the native product-card surface: white scheme, same
     radius and paddings as the recommendation cards above the fold. */
  .product-upsell__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background-color: var(--color-background);
    color: var(--color-foreground);
    border-radius: var(--product-upsell-card-radius, 30px);
    padding: 20px 20px 26px;
  }

  .product-upsell__card[data-selected] {
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  .product-upsell__media {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 18px;
    overflow: hidden;
    background-color: rgb(var(--color-foreground-rgb) / 0.05);
  }

  .product-upsell__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-upsell__flag {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 4px 12px;
    border-radius: 100px;
    background-color: var(--color-background);
    color: var(--color-foreground);
    font-size: var(--font-size--2xs, 0.6875rem);
    font-weight: 500;
    box-shadow: 0 1px 4px rgb(0 0 0 / 0.08);
  }

  .product-upsell__flag--inline {
    position: static;
    width: fit-content;
    background-color: rgb(var(--color-foreground-rgb) / 0.07);
    box-shadow: none;
  }

  .product-upsell__body {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1 1 auto;
    min-width: 0;
  }

  .product-upsell__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
  }

  .product-upsell__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .product-upsell__price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
  }

  .product-upsell__compare {
    font-size: var(--font-size--xs);
    opacity: 0.55;
  }

  .product-upsell__amount {
    font-size: 1rem;
    font-weight: 500;
  }

  .product-upsell__benefit {
    font-size: var(--font-size--xs);
    line-height: 1.45;
    opacity: 0.75;
  }

  .product-upsell__benefit p {
    margin: 0;
  }

  .product-upsell__meta {
    margin: 0;
    font-size: var(--font-size--xs);
    opacity: 0.6;
  }

  .product-upsell__actions {
    display: flex;
    align-items: center;
    margin-block-start: auto;
    padding-block-start: 4px;
  }

  .product-upsell__add,
  .product-upsell__card--topper .product-upsell__remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 100%;
  }

  .product-upsell__remove svg {
    width: 14px;
    height: 14px;
  }

  .product-upsell__remove--icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: currentcolor;
    cursor: pointer;
  }

  .product-upsell__remove--icon:hover {
    background-color: rgb(var(--color-foreground-rgb) / 0.08);
  }

  .product-upsell__remove--icon svg {
    width: 18px;
    height: 18px;
  }

  /* Gift pillow: horizontal card, full width under the topper choice */
  .product-upsell__card--gift {
    flex-direction: row;
    align-items: center;
    gap: 16px;
    margin-block-start: 12px;
    padding: 16px 20px;
  }

  .product-upsell__card--gift .product-upsell__media {
    flex: 0 0 96px;
    aspect-ratio: 1;
    border-radius: 14px;
  }

  .product-upsell__card--gift .product-upsell__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    column-gap: 12px;
    row-gap: 4px;
  }

  .product-upsell__card--gift .product-upsell__body > * {
    grid-column: 1;
  }

  .product-upsell__card--gift .product-upsell__actions {
    grid-column: 2;
    grid-row: 1 / span 4;
    margin: 0;
    padding: 0;
  }

  .product-upsell__card--gift .product-upsell__head {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .product-upsell__card--gift .product-upsell__add {
    width: auto;
  }

  /* Mobile: the row keeps a peek of the next card to invite the swipe */
  @media screen and (max-width: 749px) {
    .product-upsell__choice > .product-upsell__card {
      flex: 0 0 78%;
    }

    .product-upsell__choice > .product-upsell__card:only-child {
      flex-basis: 100%;
    }

    .product-upsell__card--gift .product-upsell__media {
      flex-basis: 72px;
    }
  }

  product-upsell[data-busy] .product-upsell__add,
  product-upsell[data-busy] .product-upsell__remove {
    opacity: 0.5;
    pointer-events: none;
  }

  .product-upsell__card--placeholder {
    justify-content: center;
    min-height: 120px;
    border: 1px dashed rgb(var(--color-foreground-rgb) / 0.35);
    font-size: var(--font-size--xs);
    opacity: 0.8;
  }

  .product-upsell__card--placeholder p {
    margin: 0;
  }

  .product-upsell__setup {
    margin: 10px 0 0;
    padding: 12px 14px;
    font-size: var(--font-size--xs);
    border: 1px dashed rgb(var(--color-foreground-rgb) / 0.35);
    border-radius: 12px;
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Upsell prodotto",
  "tag": null,
  "blocks": [
    {
      "type": "_product-upsell-card"
    }
  ],
  "settings": [
    {
      "type": "paragraph",
      "content": "Card prodotto (es. i due topper) in scelta esclusiva + cuscino in regalo con il topper, oppure scontato se preso da solo. Ogni 'Aggiungi' mette in carrello anche il materasso selezionato: si acquista il bundle."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titolo",
      "default": "Completa il tuo letto <strong>con</strong>"
    },
    {
      "type": "text",
      "id": "hint",
      "label": "Sottotitolo",
      "default": "Scegli il topper più adatto a te: puoi aggiungerne solo uno."
    },
    {
      "type": "header",
      "content": "Cuscino"
    },
    {
      "type": "product",
      "id": "gift_product",
      "label": "Prodotto"
    },
    {
      "type": "checkbox",
      "id": "gift_enabled",
      "label": "In regalo con un topper",
      "info": "Aggiunto automaticamente al carrello quando in carrello ci sono topper + materasso.",
      "default": true
    },
    {
      "type": "text",
      "id": "gift_badge",
      "label": "Etichetta quando è in regalo",
      "default": "In regalo"
    },
    {
      "type": "text",
      "id": "gift_free_label",
      "label": "Prezzo quando è in regalo",
      "default": "Gratis"
    },
    {
      "type": "inline_richtext",
      "id": "gift_text",
      "label": "Testo beneficio",
      "default": "Aggiungi un topper e il cuscino te lo regaliamo noi."
    },
    {
      "type": "text",
      "id": "gift_cart_property",
      "label": "Nota in carrello (regalo)",
      "info": "Compare in carrello sotto il cuscino come 'Omaggio: …'. Lascia vuoto per nasconderla.",
      "default": "In regalo con il topper"
    },
    {
      "type": "range",
      "id": "solo_discount_percent",
      "label": "Sconto se preso da solo (%)",
