{%- doc -%}
  Product page upsell with a guided choice:

  - Two toppers in mutually exclusive choice (adding one removes the other),
    each with its own benefit text, inheriting Dimensione/Misure from the main
    product like linked-size-add.
  - A gift pillow: added automatically (free of charge) when a topper is chosen,
    or purchasable alone at a configurable display discount.

  The block only *shows* the promotional prices. The actual cart prices must be
  backed by two automatic discounts in the Shopify admin (see the schema note).
{%- enddoc -%}

{%- liquid
  assign topper_1 = block.settings.topper_1
  assign topper_2 = block.settings.topper_2
  assign gift_product = block.settings.gift_product
-%}

<script src="{{ 'product-upsell.js' | asset_url }}" type="module"></script>

<product-upsell
  class="
    product-upsell
    {% unless block.settings.inherit_color_scheme %}color-{{ block.settings.color_scheme }}{% endunless %}
    spacing-style
  "
  style="
    {% render 'spacing-style', settings: block.settings %}
    --product-upsell-radius: {{ block.settings.border_radius }}px;
  "
  data-section-id="{{ section.id }}"
  data-gift-enabled="{{ block.settings.gift_enabled }}"
  data-solo-percent="{{ block.settings.solo_discount_percent }}"
  data-gift-cart-property="{{ block.settings.gift_cart_property | escape }}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.heading != blank -%}
    <h4 class="product-upsell__heading">{{ block.settings.heading }}</h4>
  {%- endif -%}

  {%- if block.settings.hint != blank -%}
    <p class="product-upsell__hint">{{ block.settings.hint }}</p>
  {%- endif -%}

  <div class="product-upsell__rows">
    {%- for i in (1..2) -%}
      {%- liquid
        assign product_key = 'topper_' | append: i
        assign badge_key = product_key | append: '_badge'
        assign text_key = product_key | append: '_text'
        assign topper_product = block.settings[product_key]
        assign topper_badge = block.settings[badge_key]
        assign topper_text = block.settings[text_key]
      -%}
      {%- if topper_product != blank -%}
        {% render 'product-upsell-item',
          product: topper_product,
          role: 'topper',
          badge: topper_badge,
          benefit: topper_text,
          add_label: block.settings.add_label,
          unavailable_label: block.settings.unavailable_label
        %}
      {%- endif -%}
    {%- endfor -%}

    {%- if gift_product != blank -%}
      {% render 'product-upsell-item',
        product: gift_product,
        role: 'gift',
        benefit: block.settings.gift_text,
        add_label: block.settings.add_label,
        unavailable_label: block.settings.unavailable_label,
        solo_percent: block.settings.solo_discount_percent,
        solo_badge: block.settings.solo_badge,
        gift_badge: block.settings.gift_badge,
        gift_free_label: block.settings.gift_free_label
      %}
    {%- endif -%}
  </div>

  {%- if request.design_mode -%}
    {%- if topper_1 == blank and topper_2 == blank and gift_product == blank -%}
      <p class="product-upsell__setup">
        Upsell prodotto: scegli i due topper e il cuscino nelle impostazioni del
        blocco. Il blocco resta invisibile finché non selezioni almeno un
        prodotto.
      </p>
    {%- endif -%}
  {%- endif -%}
</product-upsell>

{% stylesheet %}
  .product-upsell {
    display: block;
    width: 100%;
    border-radius: var(--product-upsell-radius, 0);
  }

  .product-upsell__heading {
    margin: 0;
  }

  .product-upsell__hint {
    margin: 4px 0 0;
    font-size: var(--font-size--xs);
    opacity: 0.7;
  }

  .product-upsell__rows {
    display: flex;
    flex-direction: column;
    margin-block-start: 6px;
  }

  .product-upsell__row {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-block: 16px;
    border-block-start: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
    transition: opacity 0.2s ease;
  }

  .product-upsell__row:first-child {
    border-block-start: 0;
  }

  .product-upsell__media {
    flex: 0 0 auto;
    width: 64px;
    height: 64px;
    border-radius: 12px;
    overflow: hidden;
    background-color: color-mix(in srgb, var(--color-foreground) 5%, transparent);
  }

  .product-upsell__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-upsell__info {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .product-upsell__badge {
    align-self: flex-start;
    font-size: var(--font-size--2xs, 0.6875rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 100px;
    background-color: color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }

  .product-upsell__title {
    margin: 0;
    font-weight: 500;
    line-height: 1.3;
  }

  .product-upsell__benefit {
    font-size: var(--font-size--xs);
    line-height: 1.4;
    opacity: 0.75;
  }

  .product-upsell__benefit p {
    margin: 0;
  }

  .product-upsell__meta {
    margin: 0;
    font-size: var(--font-size--xs);
    opacity: 0.75;
  }

  .product-upsell__price {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-wrap: wrap;
  }

  .product-upsell__compare {
    font-size: var(--font-size--xs);
    opacity: 0.55;
  }

  .product-upsell__amount {
    font-weight: 600;
  }

  .product-upsell__actions {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
  }

  .product-upsell__add {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding-block: 8px;
    padding-inline: 16px;
    min-height: 0;
    font-size: var(--font-size--sm, 0.875rem);
    border-radius: 100px;
  }

  .product-upsell__plus {
    font-weight: 600;
  }

  .product-upsell__remove {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: currentcolor;
    cursor: pointer;
  }

  .product-upsell__remove:hover {
    background-color: color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }

  .product-upsell__remove svg {
    width: 18px;
    height: 18px;
  }

  .product-upsell__row[data-selected] .product-upsell__media {
    outline: 2px solid color-mix(in srgb, var(--color-foreground) 60%, transparent);
    outline-offset: 1px;
  }

  product-upsell[data-busy] .product-upsell__add,
  product-upsell[data-busy] .product-upsell__remove {
    opacity: 0.5;
    pointer-events: none;
  }

  .product-upsell__setup {
    margin: 10px 0 0;
    padding: 12px 14px;
    font-size: var(--font-size--xs);
    border: 1px dashed color-mix(in srgb, var(--color-foreground) 35%, transparent);
    border-radius: 12px;
    opacity: 0.8;
  }
{% endstylesheet %}

