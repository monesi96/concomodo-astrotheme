      "id": "padding-block-start",
      "label": "Sopra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Sotto",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Sinistra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Destra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "paragraph",
      "content": "Importante: il blocco mostra i prezzi promo ma NON li applica. In Shopify admin → Sconti crea due sconti automatici: 1) 'Compra X ricevi Y' — compra topper + materasso, cuscino gratis; 2) sconto % sul cuscino con acquisto materasso (es. 50%). Shopify applica in automatico il più conveniente."
    }
  ],
  "presets": [
    {
      "name": "Upsell prodotto",
      "category": "t:categories.product",
      "blocks": {
        "card-1": {
          "type": "_product-upsell-card",
          "settings": {
            "badge": "Più morbidezza"
          }
        },
        "card-2": {
          "type": "_product-upsell-card",
          "settings": {
            "badge": "Più sostegno"
          }
        }
      },
      "block_order": ["card-1", "card-2"]
    }
  ]
