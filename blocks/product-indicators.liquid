      "label": "Testo info (tooltip)"
    },
    {
      "type": "text",
      "id": "firmness_min_label",
      "label": "Etichetta sinistra",
      "default": "Morbido"
    },
    {
      "type": "text",
      "id": "firmness_max_label",
      "label": "Etichetta destra",
      "default": "Rigido"
    },
    {
      "type": "header",
      "content": "Riga · Traspirabilità"
    },
    {
      "type": "checkbox",
      "id": "show_cooling",
      "label": "Mostra riga",
      "default": true
    },
    {
      "type": "text",
      "id": "cooling_label",
      "label": "Etichetta",
      "default": "Traspirabilità"
    },
    {
      "type": "image_picker",
      "id": "cooling_icon",
      "label": "Icona"
    },
    {
      "type": "textarea",
      "id": "cooling_tooltip",
      "label": "Testo info (tooltip)"
    },
    {
      "type": "text",
      "id": "cooling_min_label",
      "label": "Etichetta sinistra",
      "default": "Buona"
    },
    {
      "type": "text",
      "id": "cooling_max_label",
      "label": "Etichetta destra",
      "default": "Eccezionale"
    },
    {
      "type": "header",
      "content": "Riga · Scarico della pressione"
    },
    {
      "type": "checkbox",
      "id": "show_pressure",
      "label": "Mostra riga",
      "default": true
    },
    {
      "type": "text",
      "id": "pressure_label",
      "label": "Etichetta",
      "default": "Scarico della pressione"
    },
    {
      "type": "image_picker",
      "id": "pressure_icon",
      "label": "Icona"
    },
    {
      "type": "textarea",
      "id": "pressure_tooltip",
      "label": "Testo info (tooltip)"
    },
    {
      "type": "text",
      "id": "pressure_min_label",
      "label": "Etichetta sinistra",
      "default": "Buona"
    },
    {
      "type": "text",
      "id": "pressure_max_label",
      "label": "Etichetta destra",
      "default": "Eccezionale"
    }
  ],
  "presets": [
    {
      "name": "Indicatori prodotto"
    }
  ]
}
{% endschema %}
