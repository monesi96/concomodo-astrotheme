

{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
-%}

{% unless product_resource == blank %}
  {% render 'variant-main-picker', product_resource: product_resource %}
{% endunless %}

{% schema %}
{
  "name": "t:names.product_variant_picker",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.resource_reference_product_variant_picker"
    },
    {
      "type": "paragraph",
      "content": "t:content.edit_variants_in_theme_settings"
    },
    {
      "type": "select",
      "id": "variant_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "dropdowns",
          "label": "t:options.dropdowns"
        },
        {
          "value": "buttons",
          "label": "t:options.buttons"
        }
      ],
      "default": "buttons"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "t:settings.swatches",
      "default": true
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "staged_variant_selection",
      "label": "Mostra le altre opzioni solo dopo la scelta della Dimensione",
      "info": "Le opzioni successive (es. Lunghezza) appaiono con un'animazione dopo che il cliente sceglie la dimensione.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "split_misure",
      "label": "Dividi l'opzione Misure in Lunghezza + Larghezza",
      "info": "Con varianti tipo \"80x190\": il cliente sceglie prima la lunghezza, poi la larghezza (filtrata in base alla Dimensione). Solo con stile Pulsanti.",
      "default": true
    },
    {
      "type": "text",
      "id": "split_length_label",
      "label": "Etichetta Lunghezza",
      "default": "Lunghezza (cm)"
    },
    {
      "type": "text",
      "id": "split_width_label",
      "label": "Etichetta Larghezza",
      "default": "Larghezza (cm)"
    },
    {
      "type": "header",
      "content": "Guida alle misure",
      "info": "Pannello laterale aperto dal link accanto all'opzione Dimensione. Il contenuto è uguale per tutti i prodotti."
    },
    {
      "type": "text",
      "id": "size_guide_label",
      "label": "Testo del link",
      "default": "Guida alle misure"
    },
    {
      "type": "text",
      "id": "size_guide_title",
      "label": "Titolo del pannello",
      "default": "Guida alle misure"
    },
    {
      "type": "richtext",
      "id": "size_guide_intro",
      "label": "Testo introduttivo",
      "default": "<p><strong>Quale misura è quella giusta per te?</strong></p><p>Nella scelta del materasso contano due cose: lo spazio che hai a disposizione e chi ci dorme.</p>"
    },
    {
      "type": "richtext",
      "id": "size_guide_text_1",
      "label": "Titolo 1"
    },
    {
      "type": "image_picker",
      "id": "size_guide_image_1",
      "label": "Immagine 1"
    },
    {
      "type": "text",
      "id": "size_guide_widths_1",
      "label": "Larghezze (cm) 1",
      "info": "Valori separati da virgola, es. 80, 85, 90. Con le lunghezze genera la tabella delle misure."
    },
    {
      "type": "text",
      "id": "size_guide_lengths_1",
      "label": "Lunghezze (cm) 1",
      "default": "190, 195, 200"
    },
    {
      "type": "richtext",
      "id": "size_guide_text_2",
      "label": "Titolo 2"
    },
    {
      "type": "image_picker",
      "id": "size_guide_image_2",
      "label": "Immagine 2"
    },
    {
      "type": "text",
      "id": "size_guide_widths_2",
      "label": "Larghezze (cm) 2",
      "info": "Valori separati da virgola"
    },
    {
      "type": "text",
      "id": "size_guide_lengths_2",
      "label": "Lunghezze (cm) 2",
      "default": "190, 195, 200"
    },
    {
      "type": "richtext",
      "id": "size_guide_text_3",
      "label": "Titolo 3"
    },
    {
      "type": "image_picker",
      "id": "size_guide_image_3",
      "label": "Immagine 3"
    },
    {
      "type": "text",
      "id": "size_guide_widths_3",
      "label": "Larghezze (cm) 3",
      "info": "Valori separati da virgola"
    },
    {
      "type": "text",
      "id": "size_guide_lengths_3",
      "label": "Lunghezze (cm) 3",
      "default": "190, 195, 200"
    },
    {
      "type": "richtext",
      "id": "size_guide_text_4",
      "label": "Titolo 4"
    },
    {
      "type": "image_picker",
      "id": "size_guide_image_4",
      "label": "Immagine 4"
    },
    {
      "type": "text",
      "id": "size_guide_widths_4",
      "label": "Larghezze (cm) 4",
      "info": "Valori separati da virgola"
    },
    {
      "type": "text",
      "id": "size_guide_lengths_4",
      "label": "Lunghezze (cm) 4",
      "default": "190, 195, 200"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:names.product_variant_picker",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
