{%- doc -%}
  Renders an "add to cart" control on a recommended product card that inherits the
  Dimensione/Misure currently selected on the main product, asks the customer to
  confirm size and price, and then adds that exact variant to the cart.

  Falls back to a plain confirm-and-add for single-variant products.

  @param {object} product - The recommended product
  @param {string} section_id - The id of the section the card is rendered in
{%- enddoc -%}

{%- liquid
  assign dimensione_index = 0
  assign misure_index = 0
  for product_option in product.options_with_values
    if product_option.name == 'Dimensione'
      assign dimensione_index = forloop.index
    endif
    if product_option.name == 'Misure'
      assign misure_index = forloop.index
    endif
  endfor

  assign is_linked = false
  if dimensione_index > 0 and misure_index > 0
    assign is_linked = true
  endif

  assign is_single = false
  if product.variants.size == 1
    assign is_single = true
  endif

  assign can_render = false
  if product != blank and product.available and is_linked
    assign can_render = true
  elsif product != blank and product.available and is_single
    assign can_render = true
  endif
-%}

{%- if can_render -%}
  {%- liquid
    assign form_id = 'LinkedSizeAdd-' | append: product.id
    assign first_variant = product.selected_or_first_available_variant
    assign dialog_image = product.featured_media.preview_image | image_url: width: 240
  -%}

  <linked-size-add
    class="linked-size-add"
    data-linked="{{ is_linked }}"
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    data-bundle-main="{% if template.name == 'product' %}true{% else %}false{% endif %}"
  >
    <script type="application/json" data-linked-size-variants>
      [
        {%- for variant in product.variants -%}
          {%- liquid
            assign variant_dimensione = ''
            assign variant_misure = ''
            case dimensione_index
              when 1
                assign variant_dimensione = variant.option1
              when 2
                assign variant_dimensione = variant.option2
              when 3
                assign variant_dimensione = variant.option3
            endcase
            case misure_index
              when 1
                assign variant_misure = variant.option1
              when 2
                assign variant_misure = variant.option2
              when 3
                assign variant_misure = variant.option3
            endcase
          -%}
          {
            "id": {{ variant.id }},
            "dimensione": {{ variant_dimensione | json }},
            "misure": {{ variant_misure | json }},
            "available": {{ variant.available }},
            "price": {{ variant.price | money | json }}
            {%- if variant.compare_at_price > variant.price -%}
              , "compareAt": {{ variant.compare_at_price | money | json }}
            {%- endif -%}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>

    <button
      type="button"
      class="button linked-size-add__trigger"
      data-linked-trigger
    >
      <span data-linked-trigger-label>{{ 'actions.add_to_cart' | t }}</span>
    </button>

    <dialog class="linked-size-add__dialog" data-linked-dialog>
      {%- comment -%}
        method="dialog" makes both dismiss buttons close natively, with no JS involved.
      {%- endcomment -%}
      <form method="dialog" class="linked-size-add__dialog-inner">
        <button
          type="submit"
          class="linked-size-add__close"
          aria-label="{{ 'actions.close' | t }}"
          data-linked-cancel
        >
          {{- 'icon-close.svg' | inline_asset_content -}}
        </button>

        <p class="linked-size-add__eyebrow">Conferma la tua scelta</p>

        <div class="linked-size-add__summary">
          {%- if dialog_image != blank -%}
            <img
              class="linked-size-add__image"
              src="{{ dialog_image }}"
              alt=""
              width="80"
              height="80"
              loading="lazy"
            >
          {%- endif -%}
          <div class="linked-size-add__summary-text">
            <p class="linked-size-add__title">{{ product.title }}</p>
            <dl class="linked-size-add__specs" data-linked-specs{% unless is_linked %} hidden{% endunless %}>
              <div class="linked-size-add__spec">
                <dt>Dimensione</dt>
                <dd data-linked-dimensione>&nbsp;</dd>
              </div>
              <div class="linked-size-add__spec">
                <dt>Misure</dt>
                <dd data-linked-misure>&nbsp;</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="linked-size-add__price-row">
          <span class="linked-size-add__price-label">Prezzo</span>
          <span class="linked-size-add__price-value">
            <s class="linked-size-add__compare" data-linked-compare hidden></s>
            <span data-linked-price>{{ first_variant.price | money }}</span>
          </span>
        </div>

        {%- if is_linked -%}
          <p class="linked-size-add__note">
            La misura è la stessa che hai selezionato per il materasso.
          </p>
        {%- endif -%}

        <p class="linked-size-add__note" data-linked-bundle-note hidden>
          Aggiungiamo anche il materasso nella misura selezionata: acquisti
          tutto insieme.
        </p>

        <div class="linked-size-add__actions">
          <button type="submit" class="button-secondary linked-size-add__cancel" data-linked-cancel>
            Annulla
          </button>
          <button type="button" class="button linked-size-add__confirm" data-linked-confirm>
            Conferma e aggiungi
          </button>
        </div>
      </form>
    </dialog>

    {%- comment -%}
      Hidden, fully-functional theme product form. The confirm button clicks its submit
      button so that the cart drawer, cart bubble and error handling all keep working.
    {%- endcomment -%}
    <product-form-component
      class="linked-size-add__form"
      data-section-id="{{ section_id }}"
      data-product-id="{{ product.id }}"
      on:submit="/handleSubmit"
    >
      <div
        class="visually-hidden"
        aria-live="assertive"
        role="status"
        aria-atomic="true"
        ref="liveRegion"
      ></div>
      {%- form 'product', product, id: form_id, novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
        <input type="hidden" name="id" ref="variantId" value="{{ first_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <add-to-cart-component
          ref="addToCartButtonContainer"
          data-add-to-cart-animation="false"
        >
          <button
            type="submit"
            name="add"
            ref="addToCartButton"
            on:click="/handleClick"
            class="button linked-size-add__submit"
            tabindex="-1"
            aria-hidden="true"
            {% comment %} data-puppet skips the theme's add-to-cart animation on this hidden button {% endcomment %}
            data-puppet="true"
            data-linked-submit
          >
            {{- 'actions.add_to_cart' | t -}}
          </button>
        </add-to-cart-component>
      {%- endform -%}
    </product-form-component>
  </linked-size-add>
{%- endif -%}
