{%- doc -%}
  Renders a default variant picker, used to display the variant picker in the variants block.

  @param {object} product_resource - The product object.
  @param {object} [block] - The block object
{%- enddoc -%}

{% assign block_settings = block.settings %}

{% liquid
  assign option_names = product_resource.options_with_values | map: 'name'

  assign staged_variant_selection = false
  if block_settings.staged_variant_selection and option_names contains 'Dimensione' and option_names.size > 1
    assign staged_variant_selection = true
  endif

  # Misure divise: l'opzione "Misure" (valori "80x190") viene nascosta e pilotata
  # da due selettori sintetici Lunghezza + Larghezza, fuori da <variant-picker>.
  assign misure_split = false
  if block_settings.split_misure and block_settings.variant_style != 'dropdowns'
    for product_option in product_resource.options_with_values
      if product_option.name == 'Dimensione'
        assign dimensione_option = product_option
      endif
      if product_option.name == 'Misure'
        assign misure_first_value = product_option.values.first.name
        if misure_first_value contains 'x'
          assign misure_split = true
          assign misure_option = product_option
        endif
      endif
    endfor
  endif

  if misure_split
    assign split_length_label = block_settings.split_length_label | default: 'Lunghezza (cm)'
    assign split_width_label = block_settings.split_width_label | default: 'Larghezza (cm)'

    assign misure_selected_parts = misure_option.selected_value | split: 'x'
    assign misure_selected_width = misure_selected_parts[0]
    assign misure_selected_length = misure_selected_parts[1]

    assign misure_lengths_raw = ''
    assign misure_widths_raw = ''
    assign misure_avail_lengths_raw = ''
    assign misure_avail_widths_raw = ''
    for misure_value in misure_option.values
      assign misure_parts = misure_value.name | split: 'x'
      assign misure_widths_raw = misure_widths_raw | append: misure_parts[0] | append: ','
      assign misure_lengths_raw = misure_lengths_raw | append: misure_parts[1] | append: ','
      if misure_value.available
        assign misure_avail_widths_raw = misure_avail_widths_raw | append: misure_parts[0] | append: ','
        assign misure_avail_lengths_raw = misure_avail_lengths_raw | append: misure_parts[1] | append: ','
      endif
    endfor
    assign misure_lengths = misure_lengths_raw | split: ',' | uniq
    assign misure_widths = misure_widths_raw | split: ',' | uniq
    assign misure_avail_lengths = misure_avail_lengths_raw | split: ',' | uniq
    assign misure_avail_widths = misure_avail_widths_raw | split: ',' | uniq
  endif

  assign size_guide_label = block_settings.size_guide_label | default: 'Guida alle misure'
  assign size_guide_title = block_settings.size_guide_title | default: size_guide_label

  assign size_guide_has_content = false
  if block_settings.size_guide_intro != blank
    assign size_guide_has_content = true
  endif
  for i in (1..4)
    assign size_guide_image_key = 'size_guide_image_' | append: i
    assign size_guide_text_key = 'size_guide_text_' | append: i
    assign size_guide_widths_key = 'size_guide_widths_' | append: i
    if block_settings[size_guide_image_key] != blank or block_settings[size_guide_text_key] != blank or block_settings[size_guide_widths_key] != blank
      assign size_guide_has_content = true
    endif
  endfor
%}

<style>
  fieldset label.variant-option__button-label{
    padding: 10px 30px;
    border-radius: 200px;
  }
</style>

{% unless product_resource.has_only_default_variant %}
  {% liquid
    assign button_background_brightness = section.settings.color_scheme.settings.foreground | color_brightness
    if button_background_brightness < 105
      assign strikethrough_color_mix = '#000'
    else
      assign strikethrough_color_mix = '#fff'
    endif
  %}
  <variant-picker
    class="variant-picker spacing-style variant-picker--{{ block_settings.alignment }}"
    style="--color-strikethrough-mix: {{ strikethrough_color_mix }}; {% render 'spacing-style', settings: block_settings %}"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product_resource.id }}"
    data-block-id="{{ block.id }}"
    data-product-url="{{ product_resource.url }}"
    ref="mainVariantPicker"
    {% if product.id == product_resource.id %}
      data-template-product-match="true"
    {% endif %}
    {{ block.shopify_attributes }}
    {% if request.visual_preview_mode %}
      data-shopify-visual-preview
    {% endif %}
  >
    <form class="variant-picker__form">
      {%- for product_option in product_resource.options_with_values -%}
        {%- liquid
          assign swatch_count = product_option.values | map: 'swatch' | compact | size
          assign variant_style = block_settings.variant_style

          if swatch_count > 0 and block_settings.show_swatches
            if block_settings.variant_style == 'dropdown'
              assign variant_style = 'swatch_dropdown'
            else
              assign variant_style = 'swatch'
            endif
          endif

          if variant_style == 'buttons' and settings.variant_button_width == 'equal-width-buttons'
            assign fieldset_id = section.id | append: '-' | append: product_resource.id | append: '-' | append: product_option.name | handleize
            assign option_id_attribute = 'data-option-id="' | append: fieldset_id | append: '"'
            assign longest_value = 0
          endif
        -%}

        {%- if variant_style == 'swatch' or block_settings.variant_style == 'buttons' -%}
          {%- assign fieldset_index = forloop.index0 -%}
          {%- liquid
            assign is_misure_proxy = false
            if misure_split and product_option.name == 'Misure'
              assign is_misure_proxy = true
            endif
          -%}
          <fieldset
            class="variant-option variant-option--buttons{% if variant_style == 'swatch' %} variant-option--swatches{% else %} variant-option--{{ settings.variant_button_width }}{% endif %}{% if is_misure_proxy %} variant-option--misure-proxy{% elsif staged_variant_selection and product_option.name != 'Dimensione' %} variant-option--gated{% endif %}"
            data-option-name="{{ product_option.name | escape }}"
            data-fieldset-index="{{ fieldset_index }}"
            ref="fieldsets[]"
            {% if staged_variant_selection and product_option.name == 'Dimensione' %}
              data-gate-trigger
            {% endif %}
            {{ option_id_attribute }}
          >
            <legend>
              <div class="variant-option__legend-row">
                {{ product_option.name | escape -}}
                {% if product_option.name == 'Dimensione' and size_guide_has_content %}
                  <button
                    type="button"
                    class="button button-unstyled variant-option__swatch-value variant-option__size-guide-link"
                    on:click="#SizeGuideDrawer-{{ block.id }}/showDialog"
                    aria-haspopup="dialog"
                  >
                    {{ size_guide_label }}
                  </button>
                {% endif %}
              </div>
              {%- if variant_style == 'swatch' -%}
                <span class="variant-option__swatch-value">{{ product_option.selected_value }}</span>
              {%- endif %}
            </legend>
            {%- for product_option_value in product_option.values -%}
              {% if product_option_value.size > longest_value and option_id_attribute %}
                {% assign longest_value = product_option_value.size %}
              {% endif %}
              <label
                class="variant-option__button-label{% if variant_style == 'swatch' %} variant-option__button-label--has-swatch{% endif %}"
              >
                <input
                  type="radio"
                  name="{{ product_option.name | escape }}-{{ block.id }}-{{ product_resource.id }}"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name }}"
                  {% if product_option_value.available == false %}
                    aria-disabled="true"
                  {% endif %}
                  data-previous-checked="false"
                  data-fieldset-index="{{ fieldset_index }}"
                  data-input-index="{{ forloop.index0 }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if product_option_value.variant.id %}
                    data-variant-id="{{ product_option_value.variant.id }}"
                  {% endif %}
                  {% if product_option_value.selected %}
                    data-current-checked="true"
                    checked
                  {% else %}
                    data-current-checked="false"
                  {% endif %}
                >
                {% if variant_style == 'swatch' %}
                  {% liquid
                    assign featured_media = product_option_value.variant.featured_media

                    # If the variant has no featured media, and we have a combined listing product, then fall back to
                    # using the featured media of the child product that is linked to this option value.
                    if featured_media == blank and product_option_value.product_url
                      assign featured_media = product_option_value.variant.product.featured_media
                    endif
                  %}

                  {% render 'swatch',
                    swatch: product_option_value.swatch,
                    variant_image: featured_media,
                    mode: 'unscaled'
                  %}
                {% else %}
                  {% if product_option_value.available == true %}
                    <span
                      class="variant-option__button-label__pill"
                      data-key="variant-option-pill"
                    ></span>
                  {% endif %}
                  <span
                    class="variant-option__button-label__text"
                    data-key="variant-option-text"
                  >
                    {{- product_option_value | escape -}}
                  </span>
                {% endif %}
                {% render 'strikethrough-variant', product_option: product_option_value %}
              </label>
            {%- endfor -%}
            {% if option_id_attribute %}
              {% style %}
                [data-option-id="{{ fieldset_id }}"] {
                  --variant-ch: {{ longest_value | times: 0.65 }}em;
                }
              {% endstyle %}
            {% endif %}
          </fieldset>
        {%- elsif block_settings.variant_style == 'dropdowns' -%}
          {%
            # There is an opportunity to build a custom select component that will allow us to style the select element further (animation for dropdown, swatches shown in the dropdown options, etc)
            # It's too bad as it mean rebuilding baked in behaviours but I think we've already done that for the locale selectors
            # in dawn. So it might mean more time spent in setting it up but worth it for future updates/styling.
          %}
          {% liquid
            assign property_being_updated = false
            if settings.variant_swatch_width != settings.variant_swatch_height
              assign property_being_updated = true
              # (original width / original height) x new height (20px at the moment) = new width
              assign new_width = settings.variant_swatch_width | times: 1.0 | divided_by: settings.variant_swatch_height | times: 20
            endif
          %}

          <div
            class="variant-option variant-option--dropdowns{% if staged_variant_selection and product_option.name != 'Dimensione' %} variant-option--gated{% endif %}"
            {% if staged_variant_selection and product_option.name == 'Dimensione' %}
              data-gate-trigger
            {% endif %}
          >
            <label for="Option-{{ block.id }}-{{ forloop.index0 }}">{{ product_option.name | escape }}</label>
            <div
              class="variant-option__select-wrapper"
              style="
                {%- if property_being_updated  -%}
                  --variant-picker-swatch-width: clamp(10px,{{ new_width }}px, 50px);
                {%- endif -%}
              "
            >
              <select
                id="Option-{{ block.id }}-{{ forloop.index0 }}"
                name="options[{{ product_option.name | escape }}]"
                class="variant-option__select"
              >
                {%- for product_option_value in product_option.values -%}
                  <option
                    value="{{ product_option_value | escape }}"
                    data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                    data-option-value-id="{{ product_option_value.id }}"
                    data-variant-id="{{ product_option_value.variant.id }}"
                    data-connected-product-url="{{ product_option_value.product_url }}"
                    {% if product_option_value.selected %}
                      selected="selected"
                    {% endif %}
                  >
                    {% if product_option_value.available == false %}
                      {{ product_option_value | escape }} - {{ 'content.unavailable' | t }}
                    {% else %}
                      {{ product_option_value | escape }}
                    {% endif %}
                  </option>
                {%- endfor -%}
              </select>
              <svg
                aria-hidden="true"
                focusable="false"
                class="icon icon-caret"
                viewBox="0 0 10 6"
              >
                {%- render 'icon', icon: 'caret' -%}
              </svg>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <script type="application/json">
        {{ product_resource.selected_or_first_available_variant | json }}
      </script>
    </form>
  </variant-picker>

  {% if misure_split %}
    <misure-split-picker
      class="misure-split-picker misure-split-picker--{{ block_settings.alignment }}{% if staged_variant_selection %} misure-split-picker--staged{% endif %}"
      data-block-id="{{ block.id }}"
    >
      {% if dimensione_option %}
        {%- comment -%}
          Mappa Dimensione → misure acquistabili, usata al cambio Dimensione per
          ripiegare sulla larghezza minima e tenere sempre una variante reale selezionata.
        {%- endcomment -%}
        <script type="application/json" data-misure-matrix>
          {
            {%- for dimensione_value in dimensione_option.values -%}
              {%- assign dimensione_variants = product_resource.variants | where: 'option1', dimensione_value.name | where: 'available' -%}
              {{ dimensione_value.name | json }}: [
                {%- for dimensione_variant in dimensione_variants -%}
                  {{ dimensione_variant.option2 | json }}{% unless forloop.last %},{% endunless %}
                {%- endfor -%}
              ]{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          }
        </script>
      {% endif %}
      <fieldset
        class="variant-option variant-option--buttons variant-option--{{ settings.variant_button_width }}"
        data-misure-role="length"
        style="--variant-ch: 1.95em;"
      >
        <legend>
          <div class="variant-option__legend-row">{{ split_length_label | escape }}</div>
        </legend>
        {% for misure_length in misure_lengths %}
          <label class="variant-option__button-label">
            <input
              type="radio"
              name="MisureLunghezza-{{ block.id }}-{{ product_resource.id }}"
              value="{{ misure_length }}"
              aria-label="{{ misure_length }}"
              data-msp="length"
              data-option-available="{% if misure_avail_lengths contains misure_length %}true{% else %}false{% endif %}"
              data-previous-checked="false"
              {% if misure_length == misure_selected_length %}
                data-current-checked="true"
                checked
              {% else %}
                data-current-checked="false"
              {% endif %}
            >
            <span class="variant-option__button-label__pill"></span>
            <span class="variant-option__button-label__text">{{ misure_length }}</span>
          </label>
        {% endfor %}
      </fieldset>
      <fieldset
        class="variant-option variant-option--buttons variant-option--{{ settings.variant_button_width }}"
        data-misure-role="width"
        style="--variant-ch: 1.95em;"
      >
        <legend>
          <div class="variant-option__legend-row">{{ split_width_label | escape }}</div>
        </legend>
        {% for misure_width in misure_widths %}
          <label class="variant-option__button-label">
            <input
              type="radio"
              name="MisureLarghezza-{{ block.id }}-{{ product_resource.id }}"
              value="{{ misure_width }}"
              aria-label="{{ misure_width }}"
              data-msp="width"
              data-option-available="{% if misure_avail_widths contains misure_width %}true{% else %}false{% endif %}"
              data-previous-checked="false"
              {% if misure_width == misure_selected_width %}
                data-current-checked="true"
                checked
              {% else %}
                data-current-checked="false"
              {% endif %}
            >
            <span class="variant-option__button-label__pill"></span>
            <span class="variant-option__button-label__text">{{ misure_width }}</span>
          </label>
        {% endfor %}
      </fieldset>
    </misure-split-picker>
  {% endif %}

  {% if staged_variant_selection or misure_split %}
    <script>
      if (!window.stagedVariantSelectionInit) {
        window.stagedVariantSelectionInit = true;

        var revealGatedOptions = function (picker) {
          picker.classList.add('variant-picker--dimension-chosen');
          var wrapper = document.querySelector('misure-split-picker[data-block-id="' + (picker.dataset.blockId || '') + '"]');
          if (wrapper) wrapper.classList.add('misure-split-picker--dimension-chosen');
        };

        // Al cambio Dimensione la Misura selezionata può non esistere più
        // (le larghezze cambiano con la dimensione): ripiega sulla larghezza
        // minima disponibile mantenendo la lunghezza scelta, PRIMA che il
        // picker costruisca la richiesta, così una variante reale è sempre
        // selezionata e il prezzo resta visibile.
        var retargetMisura = function (picker, wrapper, newDimensione) {
          var matrixEl = wrapper.querySelector('script[data-misure-matrix]');
          if (!matrixEl) return;

          var matrix;
          try {
            matrix = JSON.parse(matrixEl.textContent);
          } catch (error) {
            return;
          }

          var validMisure = matrix[newDimensione];
          if (!validMisure || !validMisure.length) return;

          var currentInput = picker.querySelector('[data-option-name="Misure"] input:checked');
          var currentMisura = currentInput ? currentInput.value : '';
          if (validMisure.indexOf(currentMisura) !== -1) return;

          var currentLength = currentMisura.split('x')[1];
          var nextMisura = null;
          for (var i = 0; i < validMisure.length; i++) {
            // Le misure sono in ordine larghezza crescente: la prima con la
            // stessa lunghezza è la larghezza minima consentita.
            if (validMisure[i].split('x')[1] === currentLength) {
              nextMisura = validMisure[i];
              break;
            }
          }
          if (!nextMisura) nextMisura = validMisure[0];

          var nextInput = picker.querySelector('[data-option-name="Misure"] input[value="' + nextMisura + '"]');
          // Solo checked, senza dispatch: il fetch parte già dal change della Dimensione
          if (nextInput) nextInput.checked = true;
        };

        // Allinea i selettori sintetici Lunghezza/Larghezza allo stato reale
        // dell'opzione Misure (variante selezionata + larghezze disponibili
        // per la Dimensione corrente).
        var syncMisureSplit = function (wrapper) {
          var picker = document.querySelector('variant-picker[data-block-id="' + wrapper.dataset.blockId + '"]');
          if (!picker) return;
          var realInputs = picker.querySelectorAll('[data-option-name="Misure"] input[type="radio"]');
          if (!realInputs.length) return;

          var selectedWidth = null;
          var selectedLength = null;
          var availableWidths = {};
          var availableLengths = {};

          realInputs.forEach(function (input) {
            var parts = input.value.split('x');
            if (input.dataset.optionAvailable === 'true') {
              availableWidths[parts[0]] = true;
              availableLengths[parts[1]] = true;
            }
            if (input.checked) {
              selectedWidth = parts[0];
              selectedLength = parts[1];
            }
          });

          wrapper.querySelectorAll('input[data-msp]').forEach(function (input) {
            var isWidth = input.dataset.msp === 'width';
            var available = isWidth ? availableWidths[input.value] : availableLengths[input.value];
            input.dataset.optionAvailable = available ? 'true' : 'false';

            var shouldCheck = input.value === (isWidth ? selectedWidth : selectedLength);
            if (input.checked !== shouldCheck) input.checked = shouldCheck;
            input.dataset.currentChecked = shouldCheck ? 'true' : 'false';
            input.dataset.previousChecked = 'false';
          });
        };

        document.addEventListener(
          'change',
          function (event) {
            var target = event.target;
            if (!(target instanceof HTMLInputElement) && !(target instanceof HTMLSelectElement)) return;

            // Selettori sintetici: componi "LarghezzaxLunghezza" e attiva il radio reale
            if (target instanceof HTMLInputElement && target.dataset.msp) {
              var wrapper = target.closest('misure-split-picker');
              if (!wrapper) return;

              if (target.dataset.msp === 'length') {
                wrapper.classList.add('misure-split-picker--length-chosen');
              }

              var checkedLength = wrapper.querySelector('input[data-msp="length"]:checked');
              var checkedWidth = wrapper.querySelector('input[data-msp="width"]:checked');
              if (!checkedLength || !checkedWidth) return;

              var picker = document.querySelector('variant-picker[data-block-id="' + wrapper.dataset.blockId + '"]');
              if (!picker) return;

              var realInput = picker.querySelector(
                '[data-option-name="Misure"] input[value="' + checkedWidth.value + 'x' + checkedLength.value + '"]'
              );
              if (realInput && !realInput.checked) {
                realInput.checked = true;
                realInput.dispatchEvent(new Event('change', { bubbles: true }));
              } else if (!realInput) {
                // Combinazione inesistente: riallinea i sintetici alla variante reale
                syncMisureSplit(wrapper);
              }
              return;
            }

            // Cambio dell'opzione Dimensione (questo listener è in capture,
            // quindi gira prima che il picker costruisca la richiesta)
            if (!target.closest('[data-gate-trigger]')) return;

            var gatePicker = target.closest('variant-picker');
            if (!gatePicker) return;

            if (target instanceof HTMLInputElement) {
              var gateWrapper = document.querySelector(
                'misure-split-picker[data-block-id="' + (gatePicker.dataset.blockId || '') + '"]'
              );
              if (gateWrapper) retargetMisura(gatePicker, gateWrapper, target.value);
            }

            gatePicker.dimensionChosen = true;
            revealGatedOptions(gatePicker);
          },
          true
        );

        // Il morph post-fetch rigenera le classi dal server: ri-applica lo stato
        // e riallinea i selettori sintetici (che vivono fuori dal morph).
        document.addEventListener('variant:update', function (event) {
          var picker = event.target;
          if (!(picker instanceof HTMLElement)) return;
          if (picker.dimensionChosen) {
            revealGatedOptions(picker);
          }
          var wrapper = document.querySelector('misure-split-picker[data-block-id="' + (picker.dataset.blockId || '') + '"]');
          if (wrapper) syncMisureSplit(wrapper);
        });
      }
    </script>
  {% endif %}

  {% if size_guide_has_content and option_names contains 'Dimensione' %}
    <script
      src="{{ 'dialog.js' | asset_url }}"
      type="module"
    ></script>

    <dialog-component
      id="SizeGuideDrawer-{{ block.id }}"
      class="size-guide-drawer"
    >
      <dialog
        ref="dialog"
        class="size-guide-drawer__dialog dialog-modal dialog-drawer color-{{ settings.popover_color_scheme }}"
        scroll-lock
        aria-labelledby="SizeGuideDrawerTitle-{{ block.id }}"
      >
        <div class="size-guide-drawer__header">
          <h2
            id="SizeGuideDrawerTitle-{{ block.id }}"
            class="size-guide-drawer__title h5"
          >
            {{ size_guide_title }}
          </h2>
          <button
            ref="closeButton"
            on:click="/closeDialog"
            class="button button-unstyled close-button size-guide-drawer__close"
            aria-label="{{ 'accessibility.close_dialog' | t }}"
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
        </div>
        <div class="size-guide-drawer__content rte">
          {{ block_settings.size_guide_intro }}
          {% for i in (1..4) %}
            {% liquid
              assign size_guide_image_key = 'size_guide_image_' | append: i
              assign size_guide_text_key = 'size_guide_text_' | append: i
              assign size_guide_widths_key = 'size_guide_widths_' | append: i
              assign size_guide_lengths_key = 'size_guide_lengths_' | append: i
              assign size_guide_image = block_settings[size_guide_image_key]
              assign size_guide_text = block_settings[size_guide_text_key]
              assign size_guide_widths = block_settings[size_guide_widths_key] | split: ','
              assign size_guide_lengths = block_settings[size_guide_lengths_key] | split: ','
              assign size_guide_has_table = false
              if size_guide_widths.size > 0 and size_guide_lengths.size > 0
                assign size_guide_has_table = true
              endif
            %}
            {% if size_guide_image != blank or size_guide_text != blank or size_guide_has_table %}
              <div class="size-guide-drawer__group">
                {% if size_guide_text != blank %}
                  <div class="size-guide-drawer__group-title">
                    {{ size_guide_text }}
                  </div>
                {% endif %}
                <div class="size-guide-drawer__group-columns">
                  {% if size_guide_image != blank %}
                    <div class="size-guide-drawer__group-media">
                      {{
                        size_guide_image
                        | image_url: width: 600
                        | image_tag:
                          widths: '300, 450, 600',
                          sizes: '(min-width: 750px) 220px, 45vw',
                          class: 'size-guide-drawer__image',
                          loading: 'lazy'
                      }}
                    </div>
                  {% endif %}
                  {% if size_guide_has_table %}
                    <div class="size-guide-drawer__group-table">
                      <table class="size-guide-table">
                        <thead>
                          <tr>
                            <td
                              class="size-guide-table__corner"
                              colspan="2"
                            ></td>
                            <th
                              class="size-guide-table__lengths-label"
                              colspan="{{ size_guide_lengths.size }}"
                            >
                              Lunghezza cm
                            </th>
                          </tr>
                          <tr>
                            <td
                              class="size-guide-table__corner"
                              colspan="2"
                            ></td>
                            {% for size_guide_length in size_guide_lengths %}
                              <th class="size-guide-table__length">{{ size_guide_length | strip }}</th>
                            {% endfor %}
                          </tr>
                        </thead>
                        <tbody>
                          {% for size_guide_width in size_guide_widths %}
                            <tr>
                              {% if forloop.first %}
                                <th
                                  class="size-guide-table__axis"
                                  rowspan="{{ size_guide_widths.size }}"
                                >
                                  <span class="size-guide-table__axis-label">Larghezza cm</span>
                                </th>
                              {% endif %}
                              <th class="size-guide-table__width">{{ size_guide_width | strip }}</th>
                              {% for size_guide_length in size_guide_lengths %}
                                <td>{{ size_guide_width | strip }}x{{ size_guide_length | strip }}</td>
                              {% endfor %}
                            </tr>
                          {% endfor %}
                        </tbody>
                      </table>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </dialog>
    </dialog-component>
  {% endif %}
{% endunless %}

{% stylesheet %}
  .variant-picker {
    width: 100%;
  }

  legend {
    width: 100%;
  }

  .variant-picker__form {
    width: 100%;
  }

  .variant-picker[data-shopify-visual-preview] {
    min-width: 300px;
    padding-inline-start: max(4px, var(--padding-inline-start));
  }

  .variant-option {
    --options-border-radius: var(--variant-picker-button-radius);
    --options-border-width: var(--variant-picker-button-border-width);
    --variant-option-padding-inline: var(--padding-md);
  }

  .variant-option + .variant-option {
    margin-top: var(--padding-lg);
  }

  .variant-option--swatches {
    --options-border-radius: var(--variant-picker-swatch-radius);

    width: 100%;
  }

  .variant-option--swatches-disabled {
    pointer-events: none;
    cursor: not-allowed;
  }

  .variant-option--swatches > overflow-list {
    justify-content: var(--product-swatches-alignment);

    @media (max-width: 749px) {
      justify-content: var(--product-swatches-alignment-mobile);
    }
  }

  .variant-option--buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-sm);
    margin: 0;
    padding: 0;
    border: none;
  }

  .variant-option--buttons legend {
    padding: 0;
    margin-block-end: var(--margin-xs);
  }

  .variant-option__legend-row {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-sm);
  }

  .variant-option__swatch-value {
    padding-inline-start: var(--padding-xs);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-70));
  }

  .variant-option__size-guide-link {
    text-decoration: underline;
  }

  @media (prefers-reduced-motion: no-preference) {
    .variant-option__button-label,
    .variant-option__select-wrapper,
    .variant-option__button-label::before,
    .variant-option__button-label::after,
    .variant-option__button-label:has([data-previous-checked='true'], [data-current-checked='true'])
      .variant-option__button-label__pill,
    .variant-option__button-label:not(.variant-option__button-label--has-swatch) svg line:last-of-type {
      transition-duration: var(--animation-speed);
      transition-timing-function: var(--animation-easing);
    }

    .variant-option__button-label__pill {
      transition-property: transform;
    }

    .variant-option__button-label:not(.variant-option__button-label--has-swatch) svg line:last-of-type {
      transition-property: clip-path;
    }

    .variant-option__button-label:has([data-previous-checked='true'], [data-current-checked='true'])
      .variant-option__button-label__pill {
      transition-property: transform;
    }

    .variant-option__button-label::after {
      transition-property: clip-path;
    }

    .variant-option__button-label::before {
      transition-property: border-color;
    }

    .variant-option__select-wrapper,
    .variant-option__button-label {
      transition-property: background-color, border-color, color;
    }
  }

  .variant-option__button-label {
    --variant-picker-stroke-color: var(--color-variant-border);

    cursor: pointer;
    display: flex;
    flex: 0 0 3.25em;
    align-items: center;
    position: relative;
    padding-block: var(--padding-sm);
    padding-inline: var(--padding-lg);
    border: var(--options-border-width) solid var(--color-variant-border);
    border-radius: var(--options-border-radius);
    overflow: clip;
    justify-content: center;
    min-height: 3.25em;
    min-width: fit-content;
    white-space: nowrap;
    background-color: var(--color-variant-background);
    color: var(--color-variant-text);

    &:hover,
    &:hover:has([aria-disabled='true']):has([data-option-available='false']) {
      background-color: var(--color-variant-hover-background);
      border-color: var(--color-variant-hover-border);
      color: var(--color-variant-hover-text);
    }

    /* we need something like overflow-clip-margin to use the pseudoelement but it doesn't work in Safari */

    /* so instead use the layered background image trick */
    &:not(.variant-option__button-label--has-swatch):has([data-option-available='false']) {
      border-width: 0;
    }

    /* ::after/::before act as a fake border for the button style variant */

    /* ::after is the unavailable variant border that clips in */
    &:not(.variant-option__button-label--has-swatch)::before,
    &:has([data-option-available='false']):not(.variant-option__button-label--has-swatch)::after {
      content: '';
      position: absolute;
      inset: 0;
      border: var(--options-border-width) solid var(--color-selected-variant-border);
      border-radius: inherit;
      pointer-events: none;
      z-index: 2;
      /* stylelint-disable-next-line plugin/no-unsupported-browser-features */
      clip-path: inset(var(--clip, 0 0 0 0));
    }

    &:has([data-option-available='false']):not(.variant-option__button-label--has-swatch)::before {
      inset: 0;
    }

    &:not(.variant-option__button-label--has-swatch)::before {
      /* stylelint-disable-next-line plugin/no-unsupported-browser-features */
      clip-path: inset(0 0 0 0);
      border-color: var(--color-variant-border);
      inset: calc(var(--options-border-width) * -1);
    }

    &:has(:checked):not(.variant-option__button-label--has-swatch, :has([data-option-available='false']))::before {
      border-color: var(--color-selected-variant-border);
    }

    /* setting left/right accounts for variant buttons of different widths */
    &:not(:has(:checked)):has(~ label > :checked),
    &:has(:checked):has(~ label > [data-previous-checked='true']) {
      .variant-option__button-label__pill {
        right: 0;
        left: unset;
      }
    }

    &:has([data-previous-checked='true']) ~ label:has([data-current-checked='true']),
    &:has(:checked) ~ label {
      .variant-option__button-label__pill {
        left: 0;
        right: unset;
      }
    }

    &:not(:has(:checked)):has(~ label > :checked) {
      --pill-offset: calc(100% + 1px);
    }

    &:has(:checked) ~ label {
      --pill-offset: calc(-100% - 1px);
    }

    &:has([data-current-checked='true']):first-of-type
      ~ label:last-of-type:not(.variant-option__button-label--has-swatch),
    &:not(:has(:checked)):has(~ label > :checked):not(.variant-option__button-label--has-swatch) {
      --clip: 0 0 0 100%;
    }

    &:not(:has([data-current-checked='true'])):first-of-type:has(~ label:last-of-type > :checked):not(
        .variant-option__button-label--has-swatch
      ),
    &:has(:checked) ~ label:not(.variant-option__button-label--has-swatch) {
      --clip: 0 100% 0 0;
    }

    &:has([data-previous-checked='true'], [data-current-checked='true']) .variant-option__button-label__pill {
      width: max(var(--pill-width-current, 100%), var(--pill-width-previous, 100%));
    }

    @media screen and (min-width: 750px) {
      padding: var(--padding-xs) var(--variant-option-padding-inline);
    }
  }

  /* wrap around only for 3 or more variants in a row */

  /* the more complex selector rules here produce the wrap around effect for first/last variants */
  .variant-option--buttons:has(:nth-of-type(3)) {
    .variant-option__button-label:has([data-current-checked='true']):first-of-type ~ label:last-of-type {
      --pill-offset: calc(100% + 1px);
    }

    .variant-option__button-label:not(:has([data-current-checked='true'])):first-of-type:has(
        ~ label:last-of-type > :checked
      ) {
      --pill-offset: calc(-100% - 1px);
    }
  }

  .variant-option__button-label__pill {
    background: var(--color-selected-variant-background);
    position: absolute;
    top: calc(var(--options-border-width) * -1);
    bottom: calc(var(--options-border-width) * -1);
    border-radius: inherit;
    pointer-events: none;
    width: 100%;
    transform: translateX(var(--pill-offset, 0));
  }

  .variant-option__button-label__text {
    pointer-events: none;
    text-align: start;
    text-wrap: auto;
    z-index: 2;
  }

  .variant-option--equal-width-buttons {
    --variant-min-width: clamp(44px, calc(var(--variant-option-padding-inline) * 2 + var(--variant-ch)), 100%);

    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--variant-min-width), 1fr));

    .variant-option__button-label {
      min-width: var(--variant-min-width);
    }

    .variant-option__button-label__text {
      text-align: center;
      text-wrap: balance;
    }
  }

  .variant-option__button-label:has(:focus-visible) {
    --variant-picker-stroke-color: var(--color-foreground);

    border-color: var(--color-foreground);
    outline: var(--focus-outline-width) solid var(--color-foreground);
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__button-label--has-swatch {
    --focus-outline-radius: var(--variant-picker-swatch-radius);

    padding: 0;
    border: none;
    display: block;
    flex-basis: auto;
    min-height: auto;
  }

  .variant-option__button-label:has(:checked) {
    color: var(--color-selected-variant-text);
    border-color: var(--color-selected-variant-border);
  }

  .variant-option__button-label:has(:checked):hover {
    border-color: var(--color-selected-variant-hover-border);
    color: var(--color-selected-variant-hover-text);

    .variant-option__button-label__pill {
      background-color: var(--color-selected-variant-hover-background);
    }
  }

  .variant-option__button-label:has([data-option-available='false']),
  .variant-option__button-label input[data-option-available='false'] {
    display: none;
  }

  .facets__inputs-list--swatches-grid .variant-option__button-label--has-swatch:hover .swatch {
    --focus-outline: var(--focus-outline-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-35-55));

    outline: var(--focus-outline);
    outline-offset: var(--focus-outline-offset);
  }

  .facets__inputs-list--swatches-grid .variant-option__button-label:has(:focus-visible) .swatch {
    --focus-outline: var(--focus-outline-width) solid currentcolor;

    outline: var(--focus-outline);
    outline-offset: var(--focus-outline-offset);
  }

  .facets__inputs-list--swatches-grid .variant-option__button-label:has(:focus-visible) {
    outline: none;
  }

  .facets__inputs-list--swatches-grid .variant-option__button-label--has-swatch:hover {
    outline: none;
  }

  .variant-option__button-label--has-swatch:hover {
    outline: var(--focus-outline-width) solid rgb(var(--color-foreground-rgb) / var(--opacity-35-55));
    outline-offset: var(--focus-outline-offset);
  }

  .facets__inputs-list--swatches-grid .variant-option__button-label--has-swatch:has(:checked) {
    --focus-outline: none;
  }

  .facets__inputs-list--swatches-grid .variant-option__button-label--has-swatch:has(:checked) .swatch {
    outline: var(--focus-outline);
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__button-label--has-swatch:has(:checked) {
    --focus-outline: var(--focus-outline-width) solid var(--color-foreground);

    outline: var(--focus-outline);
    outline-offset: var(--focus-outline-offset);
  }

  /* This triggers iOS < 16.4. The outline bug is not recognized as a lack of @supports */
  @supports not (background-color: rgb(from red 150 g b / alpha)) {
    /** There is a bug in safari < 16.4 that causes the outline to not follow the elements border radius. This is a workaround. **/
    .variant-option__button-label--has-swatch:has(:checked),
    .variant-option__button-label:has(:focus-visible) .swatch,
    .facets__inputs-list--swatches-grid .variant-option__button-label--has-swatch:hover .swatch {
      outline: none;
      position: relative;
      overflow: visible;
    }

    .variant-option__button-label--has-swatch:has(:checked)::after,
    .variant-option__button-label:has(:focus-visible) .swatch::after,
    .facets__inputs-list--swatches-grid .variant-option__button-label--has-swatch:hover .swatch::after {
      content: '';
      position: absolute;
      inset: calc(-1 * var(--focus-outline-offset));
      border: var(--focus-outline);
      border-radius: var(--focus-outline-radius, 50%);
      background-color: transparent;
      display: inherit;
    }
  }

  .variant-option__button-label:has([data-option-available='false']):has(:checked) {
    background-color: inherit;
    color: rgb(var(--color-variant-text-rgb) / var(--opacity-60));
  }

  .variant-option__button-label input,
  .variant-option--images input {
    /* remove the checkbox from the page flow */
    position: absolute;

    /* set the dimensions to match those of the label */
    inset: 0;

    /* hide it */
    opacity: 0;
    margin: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .variant-option__button-label svg {
    position: absolute;
    left: var(--options-border-width);
    top: var(--options-border-width);
    height: calc(100% - (var(--options-border-width) * 2));
    width: calc(100% - (var(--options-border-width) * 2));
    cursor: pointer;
    pointer-events: none;
    stroke-width: var(--style-border-width);
    stroke: var(--variant-picker-stroke-color);
  }

  .variant-option__button-label:not(.variant-option__button-label--has-swatch) svg {
    stroke: var(--color-variant-border);

    line {
      stroke-width: var(--options-border-width);
    }

    line:last-of-type {
      /* stylelint-disable-next-line plugin/no-unsupported-browser-features */
      clip-path: inset(var(--clip, 0 0 0 0));
      stroke: rgb(var(--color-variant-text-rgb) / 1);
    }
  }

  .variant-option__select-wrapper {
    display: flex;
    position: relative;
    border: var(--style-border-width-inputs) solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    align-items: center;
    margin-top: var(--margin-2xs);
    overflow: clip;
  }

  .variant-option__select-wrapper:has(.swatch) {
    --variant-picker-swatch-width: 20px;
    --variant-picker-swatch-height: 20px;
  }

  .variant-option__select-wrapper:hover {
    border-color: var(--color-variant-hover-border);
  }

  .variant-option__select:focus-visible {
    outline: var(--focus-outline-width) solid currentcolor;
    outline-offset: var(--focus-outline-offset);
  }

  .variant-option__select {
    padding-block: var(--padding-md);
    padding-inline: var(--padding-lg) calc(var(--padding-lg) + var(--icon-size-2xs));
    appearance: none;
    border: 0;
    width: 100%;
    margin: 0;
    cursor: pointer;
  }

  .variant-option__select-wrapper .icon {
    position: absolute;
    right: var(--padding-md);
    top: 50%;
    transform: translateY(-50%);
    width: var(--icon-size-2xs);
    height: var(--icon-size-2xs);
    pointer-events: none;
  }

  .variant-option__select--has-swatch {
    padding-inline-start: calc((2 * var(--padding-sm)) + var(--variant-picker-swatch-width));
  }

  .variant-option__select-wrapper .swatch {
    position: absolute;
    top: 50%;
    left: var(--padding-md);
    transform: translateY(-50%);
  }

  .variant-picker--center,
  .variant-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .variant-picker--right,
  .variant-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }

  /* Selezione progressiva: Lunghezza visibile solo dopo la scelta della Dimensione */
  variant-picker:not(.variant-picker--dimension-chosen) .variant-option--gated {
    display: none;
  }

  .variant-picker--dimension-chosen .variant-option--gated {
    animation: variantOptionReveal calc(var(--animation-speed) * 1.5) var(--animation-easing) both;
  }

  @keyframes variantOptionReveal {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .variant-picker--dimension-chosen .variant-option--gated {
      animation: none;
    }
  }

  /* Misure divise: il fieldset reale "Misure" resta nel DOM (guida la selezione
     della variante) ma è nascosto; il cliente usa i selettori sintetici. */
  .variant-option--misure-proxy {
    display: none;
  }

  misure-split-picker {
    display: block;
  }

  .misure-split-picker .variant-option {
    margin-top: var(--padding-lg);
  }

  .misure-split-picker--center .variant-option {
    text-align: center;
    align-items: center;
    justify-content: center;
    width: 100%;
  }

  .misure-split-picker--right .variant-option {
    text-align: right;
    justify-content: right;
  }

  /* Selezione progressiva a 3 step: Lunghezza dopo la Dimensione, Larghezza dopo la Lunghezza */
  .misure-split-picker--staged:not(.misure-split-picker--dimension-chosen) [data-misure-role] {
    display: none;
  }

  .misure-split-picker--staged:not(.misure-split-picker--length-chosen) [data-misure-role='width'] {
    display: none;
  }

  .misure-split-picker--dimension-chosen [data-misure-role='length'],
  .misure-split-picker--length-chosen [data-misure-role='width'] {
    animation: variantOptionReveal calc(var(--animation-speed) * 1.5) var(--animation-easing) both;
  }

  @media (prefers-reduced-motion: reduce) {
    .misure-split-picker--dimension-chosen [data-misure-role='length'],
    .misure-split-picker--length-chosen [data-misure-role='width'] {
      animation: none;
    }
  }

  /* Size guide drawer (slide-in laterale) */
  .variant-option__size-guide-link {
    cursor: pointer;
    text-underline-offset: 3px;
    font-size: inherit;
  }

  .size-guide-drawer__dialog {
    position: fixed;
    border-radius: 0;
    width: 34rem;
    max-width: 92vw;
    height: 100%;
    margin: 0 0 0 auto;
    padding: 0;
    box-shadow: var(--shadow-popover);
  }

  /* Needed to ensure the drawer is full height */
  .size-guide-drawer__dialog:modal {
    max-height: 100dvh;
  }

  .size-guide-drawer__dialog[open] {
    display: flex;
    flex-direction: column;
  }

  .size-guide-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    flex-shrink: 0;
    padding: var(--padding-lg) var(--padding-xl);
    border-block-end: var(--style-border-width) solid var(--color-border);
  }

  .size-guide-drawer__title {
    margin: 0;
  }

  .size-guide-drawer__close {
    position: static;
    flex-shrink: 0;
  }

  .size-guide-drawer__content {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: var(--padding-xl);
  }

  .size-guide-drawer__content img {
    max-width: 100%;
    height: auto;
  }

  .size-guide-drawer__group {
    margin-block-start: var(--margin-xl);
  }

  .size-guide-drawer__group-title p {
    margin-block: 0 var(--margin-sm);
    font-weight: 700;
  }

  .size-guide-drawer__group-columns {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.5fr);
    gap: var(--gap-md);
    align-items: center;
  }

  .size-guide-drawer__group-columns:has(> :only-child) {
    grid-template-columns: minmax(0, 1fr);
  }

  .size-guide-drawer__image {
    display: block;
    width: 100%;
    margin-block: 0;
    border-radius: var(--style-border-radius-popover);
  }

  .size-guide-drawer__group-table {
    overflow-x: auto;
  }

  .size-guide-drawer__content .size-guide-table {
    border-collapse: collapse;
    text-align: center;
    font-size: 0.8125rem;
    line-height: 1.3;
  }

  /* Annulla gli stili tabella globali del tema (.rte) */
  .size-guide-drawer__content .size-guide-table :is(thead, tbody, tr, th, td) {
    background: none;
    text-transform: none;
  }

  .size-guide-drawer__content .size-guide-table :is(th, td) {
    border: 1px solid var(--color-border);
    padding: var(--padding-2xs) var(--padding-xs);
    font-weight: 400;
  }

  .size-guide-drawer__content .size-guide-table thead th,
  .size-guide-drawer__content .size-guide-table .size-guide-table__axis {
    font-weight: 600;
  }

  .size-guide-drawer__content .size-guide-table .size-guide-table__corner {
    border: none;
  }

  .size-guide-drawer__content .size-guide-table .size-guide-table__lengths-label {
    text-align: center;
    vertical-align: middle;
  }

  /* Valori Larghezza in bold come quelli Lunghezza */
  .size-guide-drawer__content .size-guide-table .size-guide-table__width {
    font-weight: 600;
  }

  /* Sfondo etichette assi */
  .size-guide-drawer__content .size-guide-table .size-guide-table__lengths-label,
  .size-guide-drawer__content .size-guide-table .size-guide-table__axis {
    background-color: #e4ded6;
  }

  /* Sfondo valori inseriti da schema (celle interne invariate) */
  .size-guide-drawer__content .size-guide-table .size-guide-table__length,
  .size-guide-drawer__content .size-guide-table .size-guide-table__width {
    background-color: #f4efe8;
  }

  .size-guide-drawer__content .size-guide-table .size-guide-table__axis {
    text-align: center;
    vertical-align: middle;
    width: 1%;
  }

  /* "Larghezza cm" in verticale, dal basso verso l'alto */
  .size-guide-table__axis-label {
    display: inline-block;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  @supports (writing-mode: sideways-lr) {
    .size-guide-table__axis-label {
      writing-mode: sideways-lr;
      transform: none;
    }
  }

  @media screen and (max-width: 479px) {
    .size-guide-drawer__group-columns {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .size-guide-drawer__dialog {
      width: 100dvw;
      max-width: 100%;
    }
  }
{% endstylesheet %}
