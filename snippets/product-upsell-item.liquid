{%- doc -%}
  Renders one card of the product upsell block, styled like the theme's native
  product cards (white rounded surface, 16/9 image, title + price row,
  full-width secondary button). Toppers render as vertical cards inside the
  choice carousel; the gift pillow renders as a horizontal full-width card.

  Toppers follow the same Dimensione/Misure matching rules as linked-size-add:
  they render only when the product shares both options with the main product,
  or when it has a single variant. The gift row always uses the first available
  variant.

  @param {object} product - The upsell product
  @param {string} role - 'topper' or 'gift'
  @param {string} badge - Static badge text (topper rows)
  @param {string} benefit - Benefit/description text shown under the title
  @param {string} add_label - Label of the add button
  @param {string} remove_label - Label of the remove button on topper cards
  @param {string} unavailable_label - Label when the inherited size is unavailable
  @param {string} card_scheme - Color scheme id for the card surface (optional)
  @param {string} shopify_attributes - Editor attributes of the owning block
  @param {number} solo_percent - Gift only: display discount % when bought alone
  @param {string} solo_badge - Gift only: badge shown when bought alone
  @param {string} gift_badge - Gift only: badge shown when a topper is selected
  @param {string} gift_free_label - Gift only: price label when free
{%- enddoc -%}

{%- liquid
  assign add_label = add_label | default: 'Aggiungi'
  assign remove_label = remove_label | default: 'Rimuovi'
  assign unavailable_label = unavailable_label | default: 'Non disponibile'

  assign dimensione_index = 0
  assign misure_index = 0
  for product_option in product.options_with_values
    if product_option.name == 'Dimensione'
      assign dimensione_index = forloop.index
    endif
    if product_option.name == 'Misure'
      assign misure_index = forloop.index
    endif
  endfor

  assign is_linked = false
  if dimensione_index > 0 and misure_index > 0
    assign is_linked = true
  endif

  assign is_single = false
  if product.variants.size == 1
    assign is_single = true
  endif

  assign can_render = false
  if product != blank and product.available
    if role == 'gift'
      assign can_render = true
    elsif is_linked or is_single
      assign can_render = true
    endif
  endif
-%}

{%- if can_render -%}
  {%- liquid
    assign row_image = product.featured_media.preview_image | image_url: width: 800

    # Server-side initial state, corrected by product-upsell.js once the cart
    # and the selected size are known: toppers show their first available
    # variant, the gift shows the "bought alone" promo price.
    assign first_variant = product.selected_or_first_available_variant
    assign initial_price = first_variant.price | money
    assign initial_compare = ''
    if first_variant.compare_at_price > first_variant.price
      assign initial_compare = first_variant.compare_at_price | money
    endif

    if role == 'gift'
      assign solo_percent = solo_percent | default: 0
      assign keep_percent = 100 | minus: solo_percent
      assign solo_cents = first_variant.price | times: keep_percent | divided_by: 100
      if solo_percent > 0
        assign initial_compare = first_variant.price | money
        assign initial_price = solo_cents | money
      endif
    endif
  -%}

  <div
    class="product-upsell__card product-upsell__card--{{ role }}{% if card_scheme != blank %} color-{{ card_scheme }}{% endif %}"
    data-upsell-row
    data-upsell-role="{{ role }}"
    data-product-id="{{ product.id }}"
    data-linked="{{ is_linked }}"
    {% if role == 'gift' %}
      data-gift-badge="{{ gift_badge | escape }}"
      data-free-label="{{ gift_free_label | escape }}"
      data-solo-badge="{{ solo_badge | escape }}"
    {% endif %}
    {{ shopify_attributes }}
  >
    <script type="application/json" data-upsell-variants>
      [
        {%- if role == 'gift' -%}
          {
            "id": {{ first_variant.id }},
            "available": {{ first_variant.available }},
            "price": {{ first_variant.price | money | json }},
            "soloPrice": {{ solo_cents | money | json }}
            {%- if first_variant.compare_at_price > first_variant.price -%}
              , "compareAt": {{ first_variant.compare_at_price | money | json }}
            {%- endif -%}
          }
        {%- else -%}
          {%- for variant in product.variants -%}
            {%- liquid
              assign variant_dimensione = ''
              assign variant_misure = ''
              case dimensione_index
                when 1
                  assign variant_dimensione = variant.option1
                when 2
                  assign variant_dimensione = variant.option2
                when 3
                  assign variant_dimensione = variant.option3
              endcase
              case misure_index
                when 1
                  assign variant_misure = variant.option1
                when 2
                  assign variant_misure = variant.option2
                when 3
                  assign variant_misure = variant.option3
              endcase
            -%}
            {
              "id": {{ variant.id }},
              "dimensione": {{ variant_dimensione | json }},
              "misure": {{ variant_misure | json }},
              "sizeLabel": {{ variant.title | json }},
              "available": {{ variant.available }},
              "price": {{ variant.price | money | json }}
              {%- if variant.compare_at_price > variant.price -%}
                , "compareAt": {{ variant.compare_at_price | money | json }}
              {%- endif -%}
            }{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        {%- endif -%}
      ]
    </script>

    <div class="product-upsell__media">
      {%- if row_image != blank -%}
        <img
          class="product-upsell__image"
          src="{{ row_image }}"
          alt="{{ product.title | escape }}"
          loading="lazy"
        >
      {%- endif -%}
      {%- if role == 'topper' and badge != blank -%}
        <span class="product-upsell__flag">{{ badge }}</span>
      {%- endif -%}
    </div>

    <div class="product-upsell__body">
      {%- if role == 'gift' -%}
        <span class="product-upsell__flag product-upsell__flag--inline" data-upsell-badge {% if solo_percent == 0 %}hidden{% endif %}>
          {{- solo_badge -}}
        </span>
      {%- endif -%}

      <div class="product-upsell__head">
        <p class="product-upsell__title">{{ product.title }}</p>
        <p class="product-upsell__price">
          <s class="product-upsell__compare" data-upsell-compare {% if initial_compare == blank %}hidden{% endif %}>
            {{- initial_compare -}}
          </s>
          <span class="product-upsell__amount" data-upsell-price>{{ initial_price }}</span>
        </p>
      </div>

      {%- if benefit != blank -%}
        <div class="product-upsell__benefit">{{ benefit }}</div>
      {%- endif -%}

      {%- unless role == 'gift' or is_single -%}
        <p class="product-upsell__meta" data-upsell-meta hidden>
          <span data-upsell-size></span>
        </p>
      {%- endunless -%}

      <div class="product-upsell__actions">
        <button
          type="button"
          class="button-secondary product-upsell__add"
          data-upsell-add
          data-label-default="{{ add_label | escape }}"
          data-label-unavailable="{{ unavailable_label | escape }}"
        >
          <span data-upsell-add-label>{{ add_label }}</span>
        </button>

        {%- if role == 'gift' -%}
          <button
            type="button"
            class="product-upsell__remove product-upsell__remove--icon"
            data-upsell-remove
            hidden
            aria-label="Rimuovi {{ product.title | escape }}"
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
        {%- else -%}
          <button
            type="button"
            class="button-secondary product-upsell__remove"
            data-upsell-remove
            hidden
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
            <span>{{ remove_label }}</span>
          </button>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- elsif request.design_mode and product != blank -%}
  <div class="product-upsell__card product-upsell__card--placeholder" {{ shopify_attributes }}>
    <p>
      "{{ product.title }}" non può ereditare la misura: servono le opzioni
      Dimensione e Misure (oppure una sola variante).
    </p>
  </div>
{%- endif -%}
