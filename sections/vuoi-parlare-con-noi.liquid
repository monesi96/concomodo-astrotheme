{%- capture icon_phone -%}<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M6.5 4h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16 16 0 0 1 4.5 6.2 2 2 0 0 1 6.5 4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M17 3.5c1.7.4 3 1.7 3.4 3.4M16 6c.9.2 1.6.9 1.8 1.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>{%- endcapture -%}
{%- capture icon_chat -%}<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M4 5.5h16v10H9l-4 3.5v-3.5H4z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><circle cx="9" cy="10.5" r="1" fill="currentColor"/><circle cx="12" cy="10.5" r="1" fill="currentColor"/><circle cx="15" cy="10.5" r="1" fill="currentColor"/></svg>{%- endcapture -%}
{%- capture icon_email -%}<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="3.5" y="5.5" width="17" height="13" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture icon_arrow -%}<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="m9 6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{%- endcapture -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} contact-cards color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %} --cc-radius: {{ section.settings.corner_radius }}px; --cc-cols: {{ section.blocks.size }};"
  {% if request.visual_preview_mode %}data-shopify-visual-preview{% endif %}
>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="contact-cards__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="contact-cards__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <div class="contact-cards__subheading">{{ section.settings.subheading }}</div>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="contact-cards__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign icon_markup = ''
          case block.settings.icon
            when 'phone'
              assign icon_markup = icon_phone
            when 'chat'
              assign icon_markup = icon_chat
            when 'email'
              assign icon_markup = icon_email
          endcase
        -%}
        {%- capture tag_open -%}
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="contact-cards__card"{% if block.settings.open_in_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}
          {%- else -%}
            <div class="contact-cards__card"
          {%- endif -%}
        {%- endcapture -%}
        {{ tag_open }} {{ block.shopify_attributes }}>
          <span class="contact-cards__icon">
            {%- if block.settings.image != blank -%}
              {% render 'image', image: block.settings.image %}
            {%- else -%}
              {{ icon_markup }}
            {%- endif -%}
          </span>
          {%- if block.settings.title != blank -%}
            <h3 class="contact-cards__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="contact-cards__card-text">{{ block.settings.text }}</div>
          {%- endif -%}
          {%- if block.settings.link != blank -%}
            <span class="contact-cards__arrow" aria-hidden="true">{{ icon_arrow }}</span>
          {%- endif -%}
        {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .contact-cards {
    --cc-radius: 24px;
  }

  .contact-cards__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 2.5rem;
  }

  .contact-cards__heading {
    margin: 0 0 0.75rem;
  }

  .contact-cards__subheading {
    opacity: 0.8;
    line-height: 1.5;
  }

  .contact-cards__subheading > :first-child { margin-block-start: 0; }
  .contact-cards__subheading > :last-child { margin-block-end: 0; }

  .contact-cards__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 1100px;
    margin-inline: auto;
  }

  @media screen and (min-width: 750px) {
    .contact-cards__grid {
      grid-template-columns: repeat(var(--cc-cols, 3), 1fr);
    }
  }

  .contact-cards__card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-radius: var(--cc-radius);
    background: rgb(var(--color-foreground-rgb) / 0.05);
    color: inherit;
    text-decoration: none;
    min-height: 100%;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  a.contact-cards__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgb(var(--color-foreground-rgb) / 0.1);
  }

  .contact-cards__icon {
    display: inline-flex;
    width: 44px;
    height: 44px;
  }

  .contact-cards__icon svg,
  .contact-cards__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .contact-cards__card-title {
    margin: 0.5rem 0 0;
    font-size: 1.35em;
  }

  .contact-cards__card-text {
    margin: 0;
    opacity: 0.75;
    line-height: 1.5;
  }

  .contact-cards__card-text > :first-child { margin-block-start: 0; }
  .contact-cards__card-text > :last-child { margin-block-end: 0; }

  .contact-cards__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    margin-block-start: auto;
    align-self: flex-end;
    border-radius: 50%;
    background: rgb(var(--color-foreground-rgb) / 0.55);
    color: var(--color-background);
  }

  .contact-cards__arrow svg {
    width: 18px;
    height: 18px;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-cards__card {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Vuoi parlare con noi?",
  "tag": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titolo",
      "default": "Vuoi parlare con noi?"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Sottotitolo",
      "default": "<p>Parla con un esperto del sonno e trova la soluzione di riposo più adatta a te.</p>"
    },
    {
      "type": "header",
      "content": "Sezione"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Raggio angoli",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "page-width", "label": "Pagina" },
        { "value": "full-width", "label": "Piena" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Sopra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Sotto",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Sinistra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Destra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card contatto",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icona",
          "options": [
            { "value": "phone", "label": "Telefono" },
            { "value": "chat", "label": "Chat" },
            { "value": "email", "label": "Email" },
            { "value": "none", "label": "Nessuna" }
          ],
          "default": "phone"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icona personalizzata (sostituisce quella sopra)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titolo",
          "default": "Chiamaci"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Testo",
          "default": "<p>Siamo qui per aiutarti a ritrovare il piacere di un sonno sereno e di qualità.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Es. tel:0800000000, mailto:info@..., link WhatsApp o pagina contatti."
        },
        {
          "type": "checkbox",
          "id": "open_in_new_tab",
          "label": "Apri in una nuova scheda",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vuoi parlare con noi?",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "phone",
            "title": "Chiamaci",
            "text": "<p>Siamo qui per aiutarti a ritrovare il piacere di un sonno sereno e di qualità.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "chat",
            "title": "Chatta con noi",
            "text": "<p>Apri la chat e ottieni subito l'assistenza di cui hai bisogno, senza perdite di tempo.</p>"
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "email",
            "title": "Inviaci un'email",
            "text": "<p>Scrivici e ti risponderemo prima che tu possa dire \"fate Concomodo\".</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
