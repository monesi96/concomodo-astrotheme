{%- comment -%}
  Product indicators: reads the product's `custom.comparison` metaobject and
  renders a set of 5-notch meters (Buona → Eccezionale) for the current product.
  Reuses the same value fields as the "Mattress comparison" section:
    · Durezza / Rigidità      → firmness_value  (+ firmness_label)
    · Traspirabilità          → cooling_value   (+ cooling_title)
    · Scarico della pressione → pressure_value  (+ pressure_title)  ← new field
  A row is hidden automatically when its value is blank.
{%- endcomment -%}

{%- liquid
  assign spec = product.metafields.custom.comparison.value

  assign firmness_value = spec.firmness_value
  assign cooling_value = spec.cooling_value
  assign pressure_value = spec.pressure_value

  assign has_firmness = false
  assign has_cooling = false
  assign has_pressure = false
  if section.settings.show_firmness and firmness_value != blank
    assign has_firmness = true
  endif
  if section.settings.show_cooling and cooling_value != blank
    assign has_cooling = true
  endif
  if section.settings.show_pressure and pressure_value != blank
    assign has_pressure = true
  endif

  assign has_any = false
  if has_firmness or has_cooling or has_pressure
    assign has_any = true
  endif
-%}

{%- if has_any -%}
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div
    class="section section--{{ section.settings.section_width }} product-indicators color-{{ section.settings.color_scheme }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %} --pi-radius: {{ section.settings.corner_radius }}px;"
    {% if request.visual_preview_mode %}data-shopify-visual-preview{% endif %}
  >
    <div class="product-indicators__inner">
      {%- if section.settings.heading != blank -%}
        <h2 class="product-indicators__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="product-indicators__list">
        {%- if has_firmness -%}
          {% render 'product-indicator-row',
            icon: section.settings.firmness_icon,
            label: section.settings.firmness_label,
            tooltip: section.settings.firmness_tooltip,
            value: firmness_value,
            min_label: section.settings.firmness_min_label,
            max_label: section.settings.firmness_max_label
          %}
        {%- endif -%}

        {%- if has_cooling -%}
          {% render 'product-indicator-row',
            icon: section.settings.cooling_icon,
            label: section.settings.cooling_label,
            tooltip: section.settings.cooling_tooltip,
            value: cooling_value,
            min_label: section.settings.cooling_min_label,
            max_label: section.settings.cooling_max_label
          %}
        {%- endif -%}

        {%- if has_pressure -%}
          {% render 'product-indicator-row',
            icon: section.settings.pressure_icon,
            label: section.settings.pressure_label,
            tooltip: section.settings.pressure_tooltip,
            value: pressure_value,
            min_label: section.settings.pressure_min_label,
            max_label: section.settings.pressure_max_label
          %}
        {%- endif -%}
      </div>
    </div>
  </div>

{%- elsif request.design_mode -%}
  <div class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style">
    <div class="product-indicators__placeholder">
      <p>Per mostrare gli indicatori, questo prodotto ha bisogno del metaobject
        <code>custom.comparison</code> con i valori (0–100):</p>
      <ul>
        <li><code>firmness_value</code> — Durezza/Rigidità {% if spec.firmness_value != blank %}✓{% else %}✗{% endif %}</li>
        <li><code>cooling_value</code> — Traspirabilità {% if spec.cooling_value != blank %}✓{% else %}✗{% endif %}</li>
        <li><code>pressure_value</code> — Scarico della pressione {% if spec.pressure_value != blank %}✓{% else %}✗{% endif %}
          <em>(campo da aggiungere alla definizione del metaobject)</em></li>
      </ul>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .product-indicators {
    --pi-radius: 20px;
    --pi-line: rgb(var(--color-foreground-rgb) / 0.12);
    --pi-fill: rgb(var(--color-foreground-rgb) / 0.55);
  }

  .product-indicators__inner {
    max-width: 720px;
    margin-inline: auto;
  }

  .product-indicators__heading {
    margin: 0 0 1.5rem;
  }

  .product-indicators__list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-indicators__row + .product-indicators__row {
    border-block-start: 1px solid var(--pi-line);
    padding-block-start: 1.5rem;
  }

  .product-indicators__head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-block-end: 0.6rem;
  }

  .product-indicators__icon {
    display: inline-flex;
    flex: none;
    width: 28px;
    height: 28px;
  }

  .product-indicators__icon img,
  .product-indicators__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-indicators__label {
    font-weight: 600;
    font-size: 1.25em;
    line-height: 1.2;
  }

  /* info button + tooltip pushed to the far right */
  .product-indicators__tip {
    position: relative;
    margin-inline-start: auto;
    display: inline-flex;
  }

  .product-indicators__tip-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    padding: 0;
    border: 0;
    border-radius: 50%;
    background: rgb(var(--color-foreground-rgb) / 0.5);
    color: var(--color-background);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    cursor: help;
  }

  .product-indicators__tip-btn:focus-visible {
    outline: 2px solid currentcolor;
    outline-offset: 2px;
  }

  .product-indicators__tip-bubble {
    position: absolute;
    inset-block-start: calc(100% + 8px);
    inset-inline-end: 0;
    z-index: 5;
    width: max-content;
    max-width: min(260px, 70vw);
    padding: 0.7rem 0.9rem;
    border-radius: 12px;
    background: rgb(var(--color-foreground-rgb) / 0.92);
    color: var(--color-background);
    font-size: 0.85em;
    font-weight: 400;
    line-height: 1.4;
    text-align: start;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    box-shadow: 0 10px 30px rgb(var(--color-foreground-rgb) / 0.25);
  }

  .product-indicators__tip:hover .product-indicators__tip-bubble,
  .product-indicators__tip:focus-within .product-indicators__tip-bubble {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* 5-notch meter (same fill logic as the comparison section) */
  .product-indicators__meter {
    display: flex;
    gap: 5px;
  }

  .product-indicators__meter-seg {
    position: relative;
    flex: 1;
    height: 8px;
    border-radius: 999px;
    background: rgb(var(--color-foreground-rgb) / 0.12);
    overflow: hidden;
  }

  .product-indicators__meter-seg::before {
    content: '';
    position: absolute;
    inset: 0;
    width: var(--f, 0%);
    border-radius: inherit;
    background: var(--pi-fill);
  }

  .product-indicators__ends {
    display: flex;
    justify-content: space-between;
    margin-block-start: 0.5rem;
    font-size: 0.9em;
    opacity: 0.65;
  }

  .product-indicators__placeholder {
    padding: 2rem;
    border: 1px dashed var(--pi-line, rgb(var(--color-foreground-rgb) / 0.3));
    border-radius: 12px;
  }

  .product-indicators__placeholder ul {
    margin-block: 0.5rem 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .product-indicators__tip-bubble {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Indicatori prodotto",
  "tag": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "I valori (0–100) vengono letti dal metaobject 'custom.comparison' del prodotto: firmness_value (durezza), cooling_value (traspirabilità), pressure_value (scarico pressione). Aggiungi il campo pressure_value alla definizione del metaobject per abilitare quella riga."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Titolo",
      "default": "Le prestazioni di questo materasso"
    },
    {
      "type": "header",
      "content": "Riga · Durezza / Rigidità"
    },
    {
      "type": "checkbox",
      "id": "show_firmness",
      "label": "Mostra riga",
      "default": true
    },
    {
      "type": "text",
      "id": "firmness_label",
      "label": "Etichetta",
      "default": "Durezza"
    },
    {
      "type": "image_picker",
      "id": "firmness_icon",
      "label": "Icona"
    },
    {
      "type": "textarea",
      "id": "firmness_tooltip",
      "label": "Testo info (tooltip)"
    },
    {
      "type": "text",
      "id": "firmness_min_label",
      "label": "Etichetta sinistra",
      "default": "Morbido"
    },
    {
      "type": "text",
      "id": "firmness_max_label",
      "label": "Etichetta destra",
      "default": "Rigido"
    },
    {
      "type": "header",
      "content": "Riga · Traspirabilità"
    },
    {
      "type": "checkbox",
      "id": "show_cooling",
      "label": "Mostra riga",
      "default": true
    },
    {
      "type": "text",
      "id": "cooling_label",
      "label": "Etichetta",
      "default": "Traspirabilità"
    },
    {
      "type": "image_picker",
      "id": "cooling_icon",
      "label": "Icona"
    },
    {
      "type": "textarea",
      "id": "cooling_tooltip",
      "label": "Testo info (tooltip)"
    },
    {
      "type": "text",
      "id": "cooling_min_label",
      "label": "Etichetta sinistra",
      "default": "Buona"
    },
    {
      "type": "text",
      "id": "cooling_max_label",
      "label": "Etichetta destra",
      "default": "Eccezionale"
    },
    {
      "type": "header",
      "content": "Riga · Scarico della pressione"
    },
    {
      "type": "checkbox",
      "id": "show_pressure",
      "label": "Mostra riga",
      "default": true
    },
    {
      "type": "text",
      "id": "pressure_label",
      "label": "Etichetta",
      "default": "Scarico della pressione"
    },
    {
      "type": "image_picker",
      "id": "pressure_icon",
      "label": "Icona"
    },
    {
      "type": "textarea",
      "id": "pressure_tooltip",
      "label": "Testo info (tooltip)"
    },
    {
      "type": "text",
      "id": "pressure_min_label",
      "label": "Etichetta sinistra",
      "default": "Buona"
    },
    {
      "type": "text",
      "id": "pressure_max_label",
      "label": "Etichetta destra",
      "default": "Eccezionale"
    },
    {
      "type": "header",
      "content": "Sezione"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Raggio angoli",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Larghezza sezione",
      "options": [
        { "value": "page-width", "label": "Pagina" },
        { "value": "full-width", "label": "Piena" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schema colore",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Sopra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Sotto",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Sinistra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Destra",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Indicatori prodotto"
    }
  ]
}
{% endschema %}
